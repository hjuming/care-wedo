# Same-origin deploy can keep this as /api.
VITE_API_BASE=/api

# LINE LIFF app ID. Leave empty for local demo mode.
VITE_LINE_LIFF_ID=

# Feedback form email delivery via EmailJS.
# Vite reads the project-root .env through care-wedo-app/vite.config.js.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
