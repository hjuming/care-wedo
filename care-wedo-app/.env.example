# Same-origin deploy can keep this as /api.
VITE_API_BASE=/api

# LINE LIFF app ID. Leave empty for local demo mode.
VITE_LINE_LIFF_ID=

# Feedback form email delivery via Cloudflare Function + EmailJS.
# In Cloudflare Pages, set these as runtime environment variables.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=

# Legacy build-time names are also supported by /api/feedback.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
