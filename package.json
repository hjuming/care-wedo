{
  "name": "care-wedo-scripts",
  "private": true,
  "type": "module",
  "scripts": {
    "backfill:scope:dry": "tsx scripts/backfill-scope.ts --dry-run",
    "backfill:scope:apply": "tsx scripts/backfill-scope.ts --apply",
    "cleanup:legacy:dry": "tsx scripts/cleanup-legacy-demo.ts",
    "cleanup:legacy:apply": "tsx scripts/cleanup-legacy-demo.ts --apply",
    "receipt-pack:check": "node scripts/validate-real-receipt-pack.mjs",
    "receipt-pack:private-check": "node scripts/validate-real-receipt-private-images.mjs",
    "receipt-pack:hashes": "node scripts/validate-real-receipt-private-images.mjs --write-hashes",
    "receipt-pack:shapes": "node scripts/real-receipt-smoke-runner.mjs --dry-run --write-shapes",
    "receipt-pack:smoke": "node scripts/real-receipt-smoke-runner.mjs --dry-run",
    "google:protected-write:smoke": "node scripts/google-protected-write-smoke.mjs",
    "google:protected-write:smoke:dry": "node scripts/google-protected-write-smoke.mjs --dry-run",
    "storage:policy:smoke": "node scripts/storage-policy-smoke.mjs",
    "storage:policy:smoke:dry": "node scripts/storage-policy-smoke.mjs --dry-run",
    "staging:smoke:ready": "node scripts/staging-smoke-readiness.mjs",
    "staging:smoke:ready:report": "node scripts/staging-smoke-readiness.mjs --report-only",
    "staging:fixture:dry": "node scripts/staging-care-fixture.mjs",
    "staging:fixture:apply": "node scripts/staging-care-fixture.mjs --apply --confirm-staging",
    "staging:migration:check": "node scripts/staging-migration-check.mjs",
    "staging:role-e2e:plan": "node scripts/staging-role-e2e.mjs",
    "staging:role-e2e": "node scripts/staging-role-e2e.mjs --confirm-staging",
    "test:staging:tooling": "node --test scripts/staging-care-fixture.test.mjs scripts/staging-migration-check.test.mjs scripts/staging-role-e2e.test.mjs",
    "rls:policy-sync": "node scripts/validate-phase59-policy-sync.mjs",
    "a11y:contrast": "node scripts/contrast-check.mjs",
    "manual:reminder": "tsx scripts/manual-reminder.ts",
    "test:functions": "tsx --test functions/_tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "env:check": "node scripts/check-env.mjs",
    "env:check:example": "node scripts/check-env.mjs --example-sync",
    "smoke:e2e": "node scripts/e2e-smoke.mjs",
    "smoke:e2e:build": "node scripts/e2e-smoke.mjs --build",
    "verify": "npm run lint --prefix care-wedo-app && npm run lint:css --prefix care-wedo-app && npm test --prefix care-wedo-app && npm run typecheck && npm run env:check:example && npm run test:functions && npm run test:staging:tooling && npm run a11y:contrast && npm run rls:policy-sync && npm run receipt-pack:check"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260706.1",
    "@types/node": "^26.1.0",
    "playwright": "^1.61.1",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3"
  }
}
