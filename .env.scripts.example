# Care WEDO — Scripts environment
# Copy to .env.scripts and fill in the values.
# This file is a committed template; never put real secrets here.
#
# Find these values in:
#   Supabase Dashboard → Project Settings → API
#   Use the "service_role" key (not the anon key).

# Staging target (leave project ref blank to use the script's locked staging ref)
CARE_WEDO_STAGING_BASE_URL=
CARE_WEDO_STAGING_PROJECT_REF=

# Three isolated staging test accounts (do not use real people or production accounts)
CARE_WEDO_FIXTURE_PRIMARY_EMAIL=
CARE_WEDO_FIXTURE_PRIMARY_PASSWORD=
CARE_WEDO_FIXTURE_COLLABORATOR_EMAIL=
CARE_WEDO_FIXTURE_COLLABORATOR_PASSWORD=
CARE_WEDO_FIXTURE_ELDER_EMAIL=
CARE_WEDO_FIXTURE_ELDER_PASSWORD=

# Filled after fixture apply; use numeric IDs from the redacted apply report
CARE_WEDO_FIXTURE_GROUP_ID=
CARE_WEDO_FIXTURE_PROFILE_ID=
CARE_WEDO_FIXTURE_MEDICATION_ID=
CARE_WEDO_E2E_ARTIFACT_DIR=

# Google protected-write / Storage smoke
CARE_WEDO_GOOGLE_ACCESS_TOKEN=
CARE_WEDO_SMOKE_PROFILE_ID=
CARE_WEDO_SMOKE_GROUP_ID=
CARE_WEDO_SMOKE_EXPECTED_USER_ID=
CARE_WEDO_STORAGE_ACCESS_TOKEN=
CARE_WEDO_STORAGE_OWNED_PATH=
CARE_WEDO_STORAGE_FOREIGN_PATH=
CARE_WEDO_STORAGE_BUCKET=
SUPABASE_PUBLISHABLE_KEY=

# Optional real-receipt regression (keep dry-run unless explicitly approved)
CARE_WEDO_REAL_RECEIPT_SMOKE_URL=
CARE_WEDO_REAL_RECEIPT_ID_TOKEN=
CARE_WEDO_REAL_RECEIPT_DRY_RUN=true

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=[REDACTED_SERVICE_ROLE_KEY]
